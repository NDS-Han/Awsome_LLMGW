# 환경 변수 템플릿
# `bash infra/deploy.sh env` 실행 시 CloudFormation Outputs에서 자동 생성된 .env가 만들어진다.
# 이 파일을 .env로 복사한 뒤 placeholder를 실제 값으로 채워도 된다.

AWS_REGION=us-east-1

# --- Aurora (RDS Data API) ---
DB_CLUSTER_ARN=arn:aws:rds:us-east-1:000000000000:cluster:agentops-aurora
DB_SECRET_ARN=arn:aws:secretsmanager:us-east-1:000000000000:secret:agentops/aurora-XXXXXX
DB_NAME=agentops

# --- Tool Router Lambda ---
TOOL_ROUTER_LAMBDA_ARN=arn:aws:lambda:us-east-1:000000000000:function:agentops-tool-router

# --- LLM ---
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# --- DynamoDB Tables ---
USAGE_TABLE=agentops-usage
DIRECTORY_TABLE=agentops-directory
BUDGET_STATE_TABLE=agentops-budget-state
CHAT_HISTORY_TABLE=agentops-chat-history
EVALUATIONS_TABLE=agentops-evaluations
SESSIONS_TABLE=agentops-sessions

# --- Cognito Auth (BFF JWT verification) ---
AUTH_MODE=cognito
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_APP_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
COGNITO_REGION=us-east-1

# --- AgentCore Gateway (OAuth client credentials) ---
COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
COGNITO_CLIENT_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
COGNITO_SCOPE=agentops-gateway/invoke
COGNITO_TOKEN_ENDPOINT=https://agentops-XXXXX.auth.us-east-1.amazoncognito.com/oauth2/token
GATEWAY_URL=https://agentops-gateway-XXXXX.gateway.bedrock-agentcore.us-east-1.amazonaws.com/mcp
AGENTCORE_REGION=us-east-1

# --- AgentCore Runtime ---
AGENTCORE_RUNTIME_ARN=arn:aws:bedrock-agentcore:us-east-1:000000000000:runtime/agentops_agent-XXXXX
AGENTCORE_LOG_GROUP_ARN=arn:aws:logs:us-east-1:000000000000:log-group:/aws/bedrock-agentcore/runtimes/agentops_agent-XXXXX
AGENTCORE_SERVICE_NAME=bedrock-agentcore
AGENTCORE_LOG_GROUP_NAME=/aws/bedrock-agentcore/runtimes/agentops_agent-XXXXX
AGENTCORE_AGENT_ID=agentops_agent-XXXXX
AGENTCORE_GATEWAY_ID=agentops-gateway-XXXXX
AGENTCORE_EVAL_ROLE_ARN=arn:aws:iam::000000000000:role/AgentOpsEvaluationRole

# --- AgentCore Registry ---
REGISTRY_ID=agentops-registry
REGISTRY_REGION=us-east-1
