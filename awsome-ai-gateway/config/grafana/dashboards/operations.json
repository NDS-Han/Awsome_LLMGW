{
  "title": "Gateway Proxy — Operations",
  "uid": "gateway-ops",
  "editable": true,
  "time": {"from": "now-3h", "to": "now"},
  "refresh": "30s",
  "panels": [
    {
      "id": 1, "title": "Request Rate (RPS)", "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{"expr": "sum(rate(gateway_request_total[1m]))", "legendFormat": ""}],
      "fieldConfig": {"defaults": {"unit": "reqps", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 5}, {"color": "red", "value": 20}]}}}
    },
    {
      "id": 2, "title": "Error Rate (1m)", "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{"expr": "sum(rate(gateway_error_total[1m]))", "legendFormat": ""}],
      "fieldConfig": {"defaults": {"unit": "reqps", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.1}, {"color": "red", "value": 1}]}}}
    },
    {
      "id": 3, "title": "Latency p99 (5m)", "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [{"expr": "histogram_quantile(0.99, sum(rate(gateway_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": ""}],
      "fieldConfig": {"defaults": {"unit": "s", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 10}, {"color": "red", "value": 30}]}}}
    },
    {
      "id": 4, "title": "Active Connections", "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [{"expr": "gateway_active_connections", "legendFormat": ""}],
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 20}, {"color": "red", "value": 100}]}}}
    },

    {
      "id": 10, "title": "Request Rate Over Time", "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {"expr": "sum(rate(gateway_request_total[1m]))", "legendFormat": "total req/s"},
        {"expr": "sum(rate(gateway_error_total[1m]))", "legendFormat": "errors/s"}
      ],
      "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"drawStyle": "line", "fillOpacity": 15}}}
    },
    {
      "id": 11, "title": "Request Duration (p50 / p95 / p99)", "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum(rate(gateway_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50"},
        {"expr": "histogram_quantile(0.95, sum(rate(gateway_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95"},
        {"expr": "histogram_quantile(0.99, sum(rate(gateway_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99"}
      ],
      "fieldConfig": {"defaults": {"unit": "s", "custom": {"drawStyle": "line", "fillOpacity": 10}}}
    },

    {
      "id": 20, "title": "Model Request Duration (p95 by model)", "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by (le, model) (rate(gateway_model_request_duration_seconds_bucket[5m])))", "legendFormat": "{{model}} p95"},
        {"expr": "histogram_quantile(0.50, sum by (le, model) (rate(gateway_model_request_duration_seconds_bucket[5m])))", "legendFormat": "{{model}} p50"}
      ],
      "fieldConfig": {"defaults": {"unit": "s", "custom": {"drawStyle": "line", "fillOpacity": 10}}}
    },
    {
      "id": 21, "title": "Error Rate by Status", "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [
        {"expr": "sum by (status) (rate(gateway_error_total[5m]))", "legendFormat": "{{status}}"},
        {"expr": "sum(rate(gateway_request_total[5m]))", "legendFormat": "total req/s"}
      ],
      "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"drawStyle": "line", "fillOpacity": 10}}}
    }
  ],
  "schemaVersion": 39
}
